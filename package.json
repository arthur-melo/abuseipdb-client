{
  "name": "abuseipdb-client",
  "version": "2.0.88",
  "private": false,
  "description": "AbuseIPDB Node.js API client.",
  "author": "Arthur Melo <contact@arthurmelo.com>",
  "homepage": "https://github.com/arthur-melo/abuseipdb-client",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup --config rollup.config.js",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage",
    "lint": "prettier -w '{lib,test}/**/*.ts' && eslint --fix '{lib,test}/**/*.ts'",
    "docs": "typedoc --plugin typedoc-plugin-replace-text",
    "prepublishOnly": "npm run test && npm run build",
    "prepare": "husky",
    "semantic-release": "cross-env HUSKY=0 semantic-release"
  },
  "dependencies": {
    "jsonapi-typescript": "^0.1.3",
    "validator": "^13.15.35",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^30.0.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "jest-fetch-mock": "^3.0.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-bundle-size": "^1.0.3",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-replace-text": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arthur-melo/abuseipdb-client.git"
  },
  "bugs": {
    "url": "https://github.com/arthur-melo/abuseipdb-client/issues"
  },
  "keywords": [
    "typescript",
    "abuseipdb",
    "node"
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
